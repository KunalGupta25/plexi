# Plexi Cloudflare Worker URL
# Default: https://plexi-worker.cosmeta.workers.dev
NEXT_PUBLIC_WORKER_URL=https://plexi-worker.cosmeta.workers.dev

# MongoDB Connection
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/plexi?retryWrites=true&w=majority

# Admin authentication (server-side secret)
ADMIN_PASSWORD=replace-with-strong-password
